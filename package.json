{
  "name": "visual-regression-ci",
  "version": "0.1.0",
  "description": "Visual regression detection for CI: Playwright screenshots + pixel diff + GPT-4o classification, with PR comments.",
  "type": "module",
  "bin": {
    "vrt": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples/cra.vrt.config.js",
    "examples/fixture.vrt.config.js",
    "examples/gitlab-ci.yml",
    "vrt.config.example.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "capture": "tsx src/capture.ts",
    "diff": "tsx src/diff.ts",
    "classify": "tsx src/classify.ts",
    "report": "tsx src/report.ts",
    "comment": "tsx src/comment.ts",
    "vrt": "tsx src/cli.ts",
    "demo": "tsx src/demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "visual-regression",
    "playwright",
    "ci",
    "screenshot-testing",
    "github-actions",
    "gpt-4o"
  ],
  "license": "MIT",
  "dependencies": {
    "openai": "^4.67.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
